---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import PostListItem from '../components/PostListItem.astro';
import FeaturedPost from '../components/FeaturedPost.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(post => !post.data.unlisted);
  const categories = [...new Set(posts.flatMap(post => post.data.tags || ['uncategorized']))];

  return categories.map(category => {
    const categoryPosts = posts.filter(post =>
      (post.data.tags || ['uncategorized']).includes(category)
    );
    const sortedPosts = categoryPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
    const latestFeaturedPost = sortedPosts.find(post => post.data.featured);

    return {
      params: { category },
      props: { posts: sortedPosts, category, latestFeaturedPost }
    };
  });
}

const { posts, category, latestFeaturedPost } = Astro.props;
const categoryName = category
  .split('-')
  .map(word => word.charAt(0).toUpperCase() + word.slice(1))
  .join(' ');

// Every category page used to share the site-wide title and description, so a
// search result for any of them read "Not So Common Thoughts" with a generic
// blurb — nothing identifying which archive it was. Search Console had these
// ranking as high as position 3 with a 0% click-through.
const pageTitle = `${categoryName} - NSCT`;
const pageDescription =
  `Writing on ${categoryName} — ${posts.length} post${posts.length === 1 ? '' : 's'} ` +
  `by A. Kohlhofer on design, technology, and the human side of creative work.`;
---

<Layout title={pageTitle} description={pageDescription}>
  <div class="w-full max-w-2xl mx-auto">
    <!-- Category Header -->
    <header class="pt-8 sm:pt-12 pb-10 sm:pb-12">
      <p class="eyebrow mb-4">Category</p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight leading-[1.08] text-ink">
        {categoryName}
      </h1>
      <p class="mt-4 text-muted">
        {posts.length} post{posts.length === 1 ? '' : 's'}
      </p>
    </header>

    {latestFeaturedPost && (
      <div class="border-t border-line pt-12 sm:pt-14">
        <FeaturedPost post={latestFeaturedPost} />
      </div>
    )}

    <!-- Posts List -->
    <section class="border-t border-line mt-12 sm:mt-14 pt-10 pb-8">
      <p class="eyebrow mb-8">Posts</p>
      <div class="space-y-10 sm:space-y-12">
        {posts
          .filter(post => post.slug !== latestFeaturedPost?.slug)
          .map(post => (
            <PostListItem post={post} />
          ))}
      </div>
    </section>
  </div>
</Layout>
