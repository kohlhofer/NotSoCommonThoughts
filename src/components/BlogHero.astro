---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date } = post.data;

// Helper to format relative time
function getRelativeTime(date) {
  const now = new Date();
  const diff = Math.floor((now - date) / 1000);

  if (diff < 0) return 'today';
  if (diff < 60) return 'today';
  if (diff < 3600) return `${Math.floor(diff / 60)} minute${Math.floor(diff / 60) === 1 ? '' : 's'} ago`;
  if (diff < 86400) return `${Math.floor(diff / 3600)} hour${Math.floor(diff / 3600) === 1 ? '' : 's'} ago`;
  if (diff < 2592000) {
    const days = Math.floor(diff / 86400);
    return days === 1 ? 'yesterday' : `${days} days ago`;
  }
  if (diff < 31536000) {
    const months = Math.floor(diff / 2592000);
    return `${months} month${months === 1 ? '' : 's'} ago`;
  }
  const years = Math.floor(diff / 31536000);
  return `${years} year${years === 1 ? '' : 's'} ago`;
}

const tags = post.data.tags || [];
const readMinutes = Math.max(1, Math.round(post.body.split(' ').length / 200));
---

<header class="max-w-2xl mx-auto pt-4 pb-10 sm:pb-12">
  <!-- Back link -->
  <a href="/" class="inline-flex items-center gap-1.5 text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-accent hover:text-accent-strong transition-colors">
    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H6M12 5l-7 7 7 7"/></svg>
    All thoughts
  </a>

  <!-- Categories -->
  {tags.length > 0 && (
    <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mt-7 text-[0.6875rem] font-semibold uppercase tracking-[0.14em] text-muted">
      {tags.map((tag, i) => {
        const tagName = tag
          .split('-')
          .map(word => word.charAt(0).toUpperCase() + word.slice(1))
          .join(' ');
        return (
          <>
            {i > 0 && <span class="text-line-strong">·</span>}
            <a href={`/${tag}`} class="hover:text-accent transition-colors">{tagName}</a>
          </>
        );
      })}
    </div>
  )}

  <!-- Title -->
  <h1 class="mt-4 text-4xl sm:text-5xl font-semibold tracking-tight leading-[1.08] text-balance text-ink">
    {title}
  </h1>

  <!-- Description -->
  {description && (
    <p class="mt-5 text-xl text-muted leading-relaxed text-balance">
      {description}
    </p>
  )}

  <!-- Meta -->
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-6 text-sm text-subtle">
    <time datetime={date.toISOString()}>{getRelativeTime(date)}</time>
    <span class="text-line-strong">·</span>
    <span>{readMinutes} min read</span>
  </div>
</header>
