---
import type { CollectionEntry } from 'astro:content';
import { formatDate } from '../utils';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, date, image, tags, useGenerativeThumbnail } = post.data;

// Extract the first image from the post content if no frontmatter image
let firstInlineImage = '';
if (!image) {
  const imageMatch = post.body.match(/!\[.*?\]\((.*?)\)/);
  if (imageMatch) {
    firstInlineImage = imageMatch[1];
  }
}

const postImage = useGenerativeThumbnail ? null : (image || firstInlineImage);

// Format tag names
const formattedTags = (tags || []).map(tag => ({
  slug: tag,
  name: tag.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')
}));
---

<article class="group">
  <div class="flex gap-5 sm:gap-8">
    <div class="flex flex-col flex-grow min-w-0">
      <time datetime={date.toISOString()} class="text-xs text-subtle">{formatDate(date)}</time>
      <h2 class="mt-1.5 text-xl sm:text-2xl font-semibold tracking-tight leading-snug text-ink">
        <a href={`/blog/${post.slug}`} class="hover:text-accent transition-colors">
          {title}
        </a>
      </h2>
      <p class="mt-2 text-base leading-relaxed text-muted">{description}</p>
      {formattedTags.length > 0 && (
        <div class="flex flex-wrap items-center gap-x-2 gap-y-1 mt-3 text-xs text-subtle">
          {formattedTags.map((tag, i) => (
            <>
              {i > 0 && <span class="text-line-strong">·</span>}
              <a href={`/${tag.slug}`} class="hover:text-accent transition-colors">{tag.name}</a>
            </>
          ))}
        </div>
      )}
    </div>
    {postImage && (
      <div class="shrink-0 w-16 sm:w-20 mt-7">
        <a href={`/blog/${post.slug}`} class="block relative rounded-lg overflow-hidden">
          <img
            src={postImage}
            alt={title}
            class="w-full opacity-95 transition-opacity group-hover:opacity-100"
          />
        </a>
      </div>
    )}
  </div>
</article>
