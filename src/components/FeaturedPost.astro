---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, image, useGenerativeThumbnail } = post.data;

// If useGenerativeThumbnail is true, we never show an image
let postImage = null;
if (!useGenerativeThumbnail) {
  if (image) {
    postImage = image;
  } else {
    const imageMatch = post.body.match(/!\[.*?\]\((.*?)\)/);
    if (imageMatch) {
      postImage = imageMatch[1];
    }
  }
}
---

<article>
  <p class="eyebrow mb-4 text-accent">Featured</p>

  <div class={`grid grid-cols-1 ${postImage ? 'sm:grid-cols-[2fr_1fr] sm:gap-10' : ''} gap-6 items-start`}>
    <div>
      <a href={`/blog/${post.slug}/`} class="group block">
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight leading-tight text-ink group-hover:text-accent transition-colors text-balance">
          {title}
        </h2>
      </a>

      <p class="mt-4 text-lg leading-relaxed text-muted">
        {description}
      </p>

      <a
        href={`/blog/${post.slug}/`}
        class="group mt-5 inline-flex items-center gap-2 text-sm font-medium text-accent hover:text-accent-strong transition-colors"
      >
        Read post
        <svg class="doorway-arrow w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h13M12 5l7 7-7 7"/></svg>
      </a>
    </div>

    {postImage && (
      <a href={`/blog/${post.slug}/`} class="block overflow-hidden rounded-lg">
        <img
          src={postImage}
          alt={title}
          class="w-full h-auto"
        />
      </a>
    )}
  </div>
</article>
