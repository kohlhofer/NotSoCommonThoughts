{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "A personal blog by A. Kohlhofer. Slate neutrals carry a dark-default reading surface, with a single red accent (red-400) as the brand voice — the same red that strikes through \"Not So\" in the wordmark.",
  "color": {
    "$type": "color",
    "background-light": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "surface-light": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.973,
          0.98,
          0.988
        ],
        "hex": "#f8fafc"
      }
    },
    "surface-light-alt": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.945,
          0.961,
          0.976
        ],
        "hex": "#f1f5f9"
      }
    },
    "background-dark": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.059,
          0.09,
          0.165
        ],
        "hex": "#0f172a"
      }
    },
    "surface-dark": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.118,
          0.161,
          0.231
        ],
        "hex": "#1e293b"
      }
    },
    "surface-dark-alt": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.2,
          0.255,
          0.333
        ],
        "hex": "#334155"
      }
    },
    "code-bg": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.11,
          0.129,
          0.157
        ],
        "hex": "#1c2128"
      }
    },
    "on-light": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.059,
          0.09,
          0.165
        ],
        "hex": "#0f172a"
      }
    },
    "on-light-muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.278,
          0.333,
          0.412
        ],
        "hex": "#475569"
      }
    },
    "on-light-subtle": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.392,
          0.455,
          0.545
        ],
        "hex": "#64748b"
      }
    },
    "on-dark": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.796,
          0.835,
          0.882
        ],
        "hex": "#cbd5e1"
      }
    },
    "on-dark-muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.58,
          0.639,
          0.722
        ],
        "hex": "#94a3b8"
      }
    },
    "on-dark-subtle": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.392,
          0.455,
          0.545
        ],
        "hex": "#64748b"
      }
    },
    "divider-light": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.886,
          0.91,
          0.941
        ],
        "hex": "#e2e8f0"
      }
    },
    "divider-dark": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.2,
          0.255,
          0.333
        ],
        "hex": "#334155"
      }
    },
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.973,
          0.443,
          0.443
        ],
        "hex": "#f87171"
      }
    },
    "primary-hover": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.988,
          0.647,
          0.647
        ],
        "hex": "#fca5a5"
      }
    },
    "prose-link-light": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.008,
          0.518,
          0.78
        ],
        "hex": "#0284c7"
      }
    },
    "prose-link-dark": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.22,
          0.741,
          0.973
        ],
        "hex": "#38bdf8"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "unit": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "gutter-sm": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "gutter-md": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "gutter-lg": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    },
    "page-top": {
      "$value": {
        "value": 64,
        "unit": "px"
      }
    },
    "sidebar": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "section": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "none": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "wordmark": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Outfit",
        "fontSize": {
          "value": 1.5,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": 0.02,
          "unit": "em"
        },
        "lineHeight": 1
      }
    },
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Outfit",
        "fontSize": {
          "value": 2.25,
          "unit": "rem"
        },
        "fontWeight": 400,
        "lineHeight": 1.2
      }
    },
    "heading-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Outfit",
        "fontSize": {
          "value": 1.875,
          "unit": "rem"
        },
        "fontWeight": 400,
        "lineHeight": 1.25
      }
    },
    "heading-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Outfit",
        "fontSize": {
          "value": 1.5,
          "unit": "rem"
        },
        "fontWeight": 400,
        "lineHeight": 1.3
      }
    },
    "heading-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Outfit",
        "fontSize": {
          "value": 1.25,
          "unit": "rem"
        },
        "fontWeight": 400,
        "lineHeight": 1.4
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Outfit",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400,
        "lineHeight": 1.7
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Outfit",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400,
        "lineHeight": 1.6
      }
    },
    "body-xs": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Outfit",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 400,
        "lineHeight": 1.5
      }
    },
    "emphasis": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Outfit",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 500
      }
    },
    "label-caps": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Outfit",
        "fontSize": {
          "value": 11,
          "unit": "px"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0.25,
          "unit": "em"
        }
      }
    },
    "serif-meta": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Georgia",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 400,
        "lineHeight": 1.6
      }
    },
    "code": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Menlo",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400,
        "lineHeight": 1.6
      }
    }
  }
}
